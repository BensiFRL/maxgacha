body {
    margin: 0px;
    padding: 0px;
}
#header {
    text-align: center;
    background-color: aquamarine;
}

#header #logo {
    left: 10px;
}

#main-home h1 {
    color: black;
    text-transform: none;
    font-weight: bold;
    font-size: 20px;
}

#main-home h2{
    color: rgb(76, 68, 165);
    text-transform: none;
    font-weight: bold;
    font-size: 15px;
    text-shadow: 3px 3px 6px #b1b1b1;
}